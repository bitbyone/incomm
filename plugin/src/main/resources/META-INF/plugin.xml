<idea-plugin>
    <id>dev.incomm</id>
    <name>incomm</name>
    <vendor>bitbyone</vendor>

    <description><![CDATA[
        <b>incomm</b> — inline code-review comments for AI agents.
        <br/>
        Attach comments to specific lines in any file. Comments are stored in
        <code>&lt;project-root&gt;/.incomm/notes.json</code> and are meant to be
        consumed and answered by an AI agent through the companion
        <code>incomm</code> CLI. Agent replies appear inline, right at the line.
    ]]></description>

    <!-- Platform-generic: works in all JetBrains IDEs. -->
    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.IncommBundle</resource-bundle>

    <extensions defaultExtensionPointName="com.intellij">
        <!-- NotesService and IncommEditorTracker are light @Service classes and
             need no registration here. -->
        <postStartupActivity implementation="dev.incomm.startup.IncommStartupActivity"/>
    </extensions>

    <projectListeners>
        <!-- Ensures the editor tracker starts as soon as a file is opened. -->
        <listener class="dev.incomm.editor.IncommFileEditorListener"
                  topic="com.intellij.openapi.fileEditor.FileEditorManagerListener"/>
    </projectListeners>

    <actions>
        <action id="incomm.AddComment"
                class="dev.incomm.actions.AddCommentAction"
                icon="/icons/addComment.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorGutterPopupMenu" anchor="last"/>
        </action>

        <action id="incomm.Reply"
                class="dev.incomm.actions.ReplyAction"
                icon="/icons/reply.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="incomm.AddComment"/>
            <add-to-group group-id="EditorGutterPopupMenu" anchor="after" relative-to-action="incomm.AddComment"/>
        </action>

        <action id="incomm.EditComment"
                class="dev.incomm.actions.EditCommentAction"
                icon="/icons/editComment.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="incomm.Reply"/>
            <add-to-group group-id="EditorGutterPopupMenu" anchor="after" relative-to-action="incomm.Reply"/>
        </action>

        <action id="incomm.ResolveThread"
                class="dev.incomm.actions.ResolveThreadAction"
                icon="/icons/commentResolved.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="incomm.EditComment"/>
            <add-to-group group-id="EditorGutterPopupMenu" anchor="after" relative-to-action="incomm.EditComment"/>
        </action>

        <action id="incomm.ToggleThread"
                class="dev.incomm.actions.ToggleThreadAction"
                icon="/icons/comment.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="incomm.ResolveThread"/>
            <add-to-group group-id="EditorGutterPopupMenu" anchor="after" relative-to-action="incomm.ResolveThread"/>
        </action>

        <action id="incomm.DeleteThread"
                class="dev.incomm.actions.DeleteThreadAction"
                icon="/icons/deleteComment.svg">
            <add-to-group group-id="EditorPopupMenu" anchor="after" relative-to-action="incomm.ToggleThread"/>
            <add-to-group group-id="EditorGutterPopupMenu" anchor="after" relative-to-action="incomm.ToggleThread"/>
        </action>

        <action id="incomm.ShowComments"
                class="dev.incomm.actions.ShowCommentsAction"
                icon="/icons/comment.svg">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="incomm.ToggleNotes"
                class="dev.incomm.actions.ToggleNotesAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="incomm.ToggleResolved"
                class="dev.incomm.actions.ToggleResolvedNotesAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="incomm.ClearFile"
                class="dev.incomm.actions.ClearFileAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="incomm.Clear"
                class="dev.incomm.actions.ClearAction">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
